# =============================================================================
# AttendQR – .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Entorno y configuración local
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local

# -----------------------------------------------------------------------------
# Dependencias (Composer – cuando se incorpore)
# -----------------------------------------------------------------------------
/vendor/
composer.lock

# -----------------------------------------------------------------------------
# Almacenamiento generado en runtime
# -----------------------------------------------------------------------------
/storage/logs/*
!/storage/logs/.gitkeep

/storage/temp/*
!/storage/temp/.gitkeep

/storage/qr/*
!/storage/qr/.gitkeep

# -----------------------------------------------------------------------------
# IDEs y editores
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.sublime-project
*.sublime-workspace
nbproject/
.netbeans/

# -----------------------------------------------------------------------------
# Sistema operativo
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# -----------------------------------------------------------------------------
# PHP
# -----------------------------------------------------------------------------
*.cache
*.tmp

# -----------------------------------------------------------------------------
# Archivos de log sueltos
# -----------------------------------------------------------------------------
*.log
error_log

/node_modules/
coverage/
.phpunit.result.cache